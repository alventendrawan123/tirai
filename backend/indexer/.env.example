# Tirai Indexer — environment variables
# Copy to .env (gitignored) and fill in values for local dev.
# In Railway, set these via Variables panel.

# Supabase (required)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx_service_role_key

# Solana RPC (required) — devnet, ideally Helius/QuickNode for stability
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Cloak program ID (optional — defaults to devnet)
CLOAK_PROGRAM_ID=Zc1kHfp4rajSMeASFDwFFgkHRjv7dFQuLheJoQus27h

# Poll interval in ms (optional — default 30s)
POLL_INTERVAL_MS=30000

# RPC batch size for getTransaction calls (optional — default 10)
# Helius free tier: keep ≤10 to avoid 429
BATCH_SIZE=10

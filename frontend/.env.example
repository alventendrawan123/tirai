NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_RPC_PROXY_PATH=/api/rpc

# Optional: override the WebSocket endpoint used for tx confirmation
# subscriptions. Defaults to the cluster's public WS:
#   devnet  -> wss://api.devnet.solana.com
#   mainnet -> wss://api.mainnet-beta.solana.com
#   localnet -> ws://localhost:8900
# NEXT_PUBLIC_SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=...

SOLANA_RPC_URL=https://api.devnet.solana.com
